    given-names: M Ehsan
    affiliation: "University of British Columbia"
    orcid: "https://orcid.org/0000-0002-0346-2871"
repository-code: "https://github.com/ehsanx/Survey-TMLE-codes"
url: "https://ehsank.com/"
license: GPL-3.0-or-later
keywords:
  - targeted maximum likelihood estimation
  - causal inference
  - complex surveys
  - cross-fitting
  - design-based variance
  - NHANES
