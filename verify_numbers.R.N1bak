chk("manuscript.Rmd Sec5", "R01 csv: complex/standard(A)/L1/Fully-Aware-CF bias -> +0.02",
    "+0.02", sprintf("%+.2f", R01("complex","standard","L1_param","Fully-Aware-CF","bias")),
