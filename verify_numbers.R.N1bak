    eqd(-0.004, R01("simple","standard","L1_param","Fully-Aware-CF","bias"), 3))
chk("appendix.Rmd WebD-control", "R01 csv: simple/R1(B)/L1/Fully-Aware-CF bias",
    "-0.002", sprintf("%+.3f", R01("simple","R1","L1_param","Fully-Aware-CF","bias")),
